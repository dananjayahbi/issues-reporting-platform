# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/llc_itp?schema=public"

# Authentication
AUTH_SECRET="your-super-secret-auth-secret-min-32-chars-here"
AUTH_URL="http://localhost:3000"

# SMTP / Email
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@llc.local"
SMTP_PASS="your-smtp-password"
SMTP_FROM="LLC-ITP <noreply@llc.local>"

# File Uploads
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE="10485760"

# Application
NODE_ENV="development"
